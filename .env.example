# VWAP Strategy Bot environment file
# Copy this file to .env and fill in your own values.

# Angel One SmartAPI credentials
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_MPIN=your_mpin_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# Strategy parameters
INDEX=NIFTY
ATM_OFFSET=100
CE_ITM_OFFSET=100
PE_ITM_OFFSET=100
LOTS=1
LOT_SIZE=75
MAX_TRADES_DAY=3
SIGNAL_EXPIRY_CANDLES=2

# Trading window (IST)
MARKET_START=10:30
MARKET_END=15:00
CHECK_INTERVAL=60
LTP_CHECK_INTERVAL=1

# Risk controls
MAX_DAILY_LOSS=2000
MAX_DAILY_PROFIT=10000

# Mode
PAPER_TRADE=True
USE_MOCK_DATA=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
