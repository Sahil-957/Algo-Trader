ANGEL_TOTP_SECRET=WVDZSEVDWQP2KECFUJTLPWOH6E

# ── Strategy Parameters ───────────────────────────────────────────
INDEX=NIFTY               # NIFTY | BANKNIFTY | FINNIFTY
ATM_OFFSET=100            # Points away from ATM (100 for NIFTY)
LOTS=1                    # Number of lots per trade
LOT_SIZE=65               # NIFTY lot size = 50, BANKNIFTY = 15
MAX_TRADES_DAY=10          # Maximum trades allowed per day
SIGNAL_EXPIRY_CANDLES=1   # Crossover valid for 2 candles (5 min)

# ── Trading Window (IST 24h format) ──────────────────────────────
# MARKET_START=10:30
# MARKET_END=15:00
# CHECK_INTERVAL=60         # Seconds between each bot cycle
MARKET_START=00:00
MARKET_END=23:59
CHECK_INTERVAL=10

# ── Risk Controls (₹) ────────────────────────────────────────────
MAX_DAILY_LOSS=2000       # Bot stops if daily loss reaches this
MAX_DAILY_PROFIT=10000    # Bot stops if daily profit reaches this

# ── Mode ──────────────────────────────────────────────────────────
# Set to True for paper trading (no real orders placed)
# Set to False for live trading
PAPER_TRADE=True
USE_MOCK_DATA=False
