# ─────────────────────────────────────────────────────────────────
# VWAP STRATEGY BOT — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Angel One Smart API Credentials ──────────────────────────────
ANGEL_API_KEY=xy7qRC5k
ANGEL_CLIENT_ID=S54392980
ANGEL_MPIN=9570
ANGEL_TOTP_SECRET=WVDZSEVDWQP2KECFUJTLPWOH6E

# ── Strategy Parameters ───────────────────────────────────────────
INDEX=NIFTY
ATM_OFFSET=100
CE_ITM_OFFSET=100
PE_ITM_OFFSET=100
LOTS=1
LOT_SIZE=65
MAX_TRADES_DAY=10
SIGNAL_EXPIRY_CANDLES=2  # Crossover valid for 2 candles (5 min)

# ── Trading Window (IST 24h format) ──────────────────────────────
# MARKET_START=10:30
# MARKET_END=15:00
# CHECK_INTERVAL=60         # Seconds between each bot cycle
MARKET_START=9:15
MARKET_END=15:30
CHECK_INTERVAL=60
LTP_CHECK_INTERVAL=1
USE_WEBSOCKET=True
STALE_LTP_THRESHOLD_SEC=30

# ── Risk Controls (₹) ────────────────────────────────────────────
MAX_DAILY_LOSS=20000       # Bot stops if daily loss reaches this
MAX_DAILY_PROFIT=100000    # Bot stops if daily profit reaches this
RR_RATIO=2.0               # Target = Entry + (RR_RATIO × Risk)
FIXED_TARGET=10    # Fixed ₹ target from entry (overrides RR_RATIO when > 0)

# ── Trailing Stop Loss ─────────────────────────────────────────────
TRAILING_SL=False          # Set to True to enable trailing SL
BREAKEVEN_AT=0.5           # Move SL to entry when this fraction of target is reached (0.5 = 50%)
TRAIL_POINTS=5          # After breakeven, trail SL this many points below peak LTP (0 = breakeven only)

# ── Mode ──────────────────────────────────────────────────────────
# Set to True for paper trading (no real orders placed)
# Set to False for live trading
PAPER_TRADE=True
USE_MOCK_DATA=False
TELEGRAM_BOT_TOKEN=8677730488:AAHmt0FOO5AsGjB4JZXPgNY0wNLz8m22kfc
TELEGRAM_CHAT_ID=5517433791
